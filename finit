<title>Antalya'nın Vahası</title>
<style>
  /* (Kodunuzdaki diğer CSS kısımları aynen korunmuştur) */
  body, html {
    margin: 0; padding: 0; font-family: Arial, sans-serif; color: #333;
    height: 100%;
    background: url('https://r.resimlink.com/06HMFl.png') no-repeat center center fixed;
    background-size: cover;
  }

  nav {
    position: fixed;
    top: 0; 
    width: 100%;
    background-color: rgba(0,0,0,0.6);
    display: flex;
    justify-content: center;
    gap: 30px;
    padding: 15px 0;
    z-index: 1000;
  }

  nav a {
    color: white;
    font-weight: bold;
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 1.1em;
  }

  nav a:hover {
    color: #ffcc00;
  }

  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 20px;
  }

  .overlay {
    background-color: rgba(0, 0, 0, 0.55);
    padding: 40px 30px;
    border-radius: 15px;
    color: white;
    max-width: 800px;
    text-shadow: 0 0 10px rgba(0,0,0,0.7);
  }

  .overlay h1 {
    font-size: 3.2em;
    margin-bottom: 0.3em;
  }

  .overlay p {
    font-size: 1.5em;
  }

  section {
    background-color: rgba(255, 255, 255, 0.95);
    padding: 60px 20px;
    max-width: 1100px;
    margin: 40px auto;
    border-radius: 15px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  h2 {
    color: #006633;
    margin-bottom: 20px;
    border-bottom: 3px solid #ffcc00;
    display: inline-block;
    padding-bottom: 5px;
  }

  .area-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .area-item {
    background: white;
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.15);
    cursor: pointer;
    transition: box-shadow 0.3s ease;
  }

  .area-item:hover {
    box-shadow: 0 8px 25px rgba(0,0,0,0.25);
  }

  .area-item h3 {
    margin-top: 0;
    color: #004d00;
  }

  .area-item p {
    line-height: 1.5;
  }

  form {
    background: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 3px 15px rgba(0,0,0,0.12);
    max-width: 600px;
    margin: 0 auto;
  }

  form label {
    display: block;
    font-weight: bold;
    margin-top: 15px;
  }

  form input, form textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    border-radius: 6px;
    border: 1px solid #ccc;
    resize: vertical;
  }

  form button {
    margin-top: 20px;
    background-color: #006633;
    color: white;
    font-weight: bold;
    border: none;
    padding: 12px 25px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1.1em;
    transition: background-color 0.3s ease;
  }

  form button:hover {
    background-color: #004d00;
  }

  footer {
    text-align: center;
    padding: 20px;
    font-size: 0.9em;
    background: #006633;
    color: white;
    margin-top: 50px;
    border-radius: 0 0 15px 15px;
  }

  @media (max-width: 600px) {
    .overlay h1 {
      font-size: 2em;
    }
    .overlay p {
      font-size: 1.1em;
    }
  }

  .modal {
    display: none;
    position: fixed;
    z-index: 2500;
    left: 0; top: 0;
    width: 100%; height: 100%;
    overflow-y: auto;
    background-color: rgba(0, 0, 0, 0.5);
  }
  .modal-content {
    background-color: #fff;
    margin: 80px auto;
    padding: 25px 30px;
    border-radius: 20px;
    width: 95%;
    max-width: 720px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    position: relative;
  }
  .close-btn {
    position: absolute;
    right: 20px; top: 15px;
    font-size: 32px;
    font-weight: bold;
    background: none;
    border: none;
    color: #555;
    cursor: pointer;
  }
  .close-btn:hover {
    color: #000;
  }
  .modal-img {
    width: 100%;
    max-height: 400px;
    object-fit: contain;
    border-radius: 14px;
    margin-bottom: 20px;
  }
  .modal-text {
    font-size: 1.15em;
    white-space: pre-line;
    line-height: 1.6;
  }
</style>
</head>
